rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /challenges/{challengeId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && fileName.matches('.*[.](jpg|jpeg|png|webp)$')
        && request.resource.size < 15 * 1024 * 1024;
    }

    match /challenges/{challengeId}/run-uploads/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && fileName.matches('.*[.](jpg|jpeg|png|webp)$')
        && request.resource.size < 15 * 1024 * 1024;
    }

    /** Tourgo Friends · v5 — headshot photos (one per player per room). */
    match /hideSeekHeadshots/{roomCode}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && roomCode.matches('^[A-Z0-9]{4,8}$')
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    /** Tourgo Friends · v5 — Runner position photos (multiple per game). */
    match /hideSeekPositions/{roomCode}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && roomCode.matches('^[A-Z0-9]{4,8}$')
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
