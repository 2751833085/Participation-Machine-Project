rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * User reports on hunt listings (Open hunts). Create = signed-in only;
     * read open for admin dashboard (same model as attempts — tighten for production).
     */
    match /challengeReports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'challengeId', 'category', 'details', 'challengeTitleSnapshot',
          'reporterUid', 'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'challengeId', 'category', 'details', 'challengeTitleSnapshot',
          'reporterUid', 'createdAt'
        ])
        && request.resource.data.challengeId is string
        && request.resource.data.challengeId.size() > 0
        && request.resource.data.challengeId.size() < 256
        && request.resource.data.category is string
        && request.resource.data.category in [
          'spam_misleading', 'harassment', 'illegal', 'image_distressing',
          'copyright', 'other'
        ]
        && request.resource.data.details is string
        && request.resource.data.details.size() <= 2000
        && request.resource.data.challengeTitleSnapshot is string
        && request.resource.data.challengeTitleSnapshot.size() <= 200
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && exists(/databases/$(database)/documents/challenges/$(request.resource.data.challengeId));
      allow update, delete: if false;
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.timeLimitMinutes is int
        && request.resource.data.timeLimitMinutes > 0
        && request.resource.data.timeLimitMinutes <= 24 * 60
        && (!('huntHint' in request.resource.data)
          || (request.resource.data.huntHint is string
            && request.resource.data.huntHint.size() <= 800));
      allow update, delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    match /attempts/{attemptId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.challengeId is string;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.challengeId == resource.data.challengeId
        && request.resource.data.startedAt == resource.data.startedAt
        && request.resource.data.deadlineAt == resource.data.deadlineAt
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['foundSpotIndices', 'status', 'completedAt']);
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /favoritedHunts/{challengeId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && challengeId is string
          && challengeId.size() > 0
          && challengeId.size() < 256
          && request.resource.data.keys().hasOnly(['createdAt'])
          && request.resource.data.createdAt == request.time
          && exists(/databases/$(database)/documents/challenges/$(challengeId));
        allow delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }
    }

    match /userHandles/{handleId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid
        && handleId is string
        && handleId.size() >= 2
        && handleId.size() <= 32;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /runPhotos/{photoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.challengeId is string
        && request.resource.data.attemptId is string
        && request.resource.data.spotIndex is int
        && request.resource.data.spotIndex >= 0
        && request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.matches('https://.*')
        && request.resource.data.keys().hasAll([
          'challengeId', 'attemptId', 'userId', 'spotIndex', 'imageUrl', 'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'challengeId', 'attemptId', 'userId', 'spotIndex', 'imageUrl', 'createdAt', 'authorName'
        ])
        && (!('authorName' in request.resource.data)
          || (request.resource.data.authorName is string
            && request.resource.data.authorName.size() <= 48))
        && exists(/databases/$(database)/documents/challenges/$(request.resource.data.challengeId))
        && get(/databases/$(database)/documents/challenges/$(request.resource.data.challengeId)).data.spots is list
        && request.resource.data.spotIndex
          < get(/databases/$(database)/documents/challenges/$(request.resource.data.challengeId)).data.spots.size()
        && exists(/databases/$(database)/documents/attempts/$(request.resource.data.attemptId))
        && get(/databases/$(database)/documents/attempts/$(request.resource.data.attemptId)).data.userId
          == request.auth.uid
        && get(/databases/$(database)/documents/attempts/$(request.resource.data.attemptId)).data.challengeId
          == request.resource.data.challengeId
        && get(/databases/$(database)/documents/attempts/$(request.resource.data.attemptId)).data.status
          == 'active';
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if false;

      match /votes/{voteUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && voteUid == request.auth.uid
          && request.resource.data.keys().hasOnly(['vote', 'mood'])
          && request.resource.data.vote in ['up', 'down', '']
          && request.resource.data.mood in ['laugh', 'cry', 'awkward', ''];
        allow delete: if request.auth != null && voteUid == request.auth.uid;
      }

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 500
          && request.resource.data.keys().hasAll(['userId', 'text', 'createdAt'])
          && request.resource.data.keys().hasOnly([
            'userId', 'text', 'createdAt', 'parentCommentId', 'authorName'
          ])
          && (!('parentCommentId' in request.resource.data)
            || request.resource.data.parentCommentId is string)
          && (!('authorName' in request.resource.data)
            || (request.resource.data.authorName is string
              && request.resource.data.authorName.size() <= 48));
        allow update, delete: if request.auth != null
          && resource.data.userId == request.auth.uid;

        match /votes/{voteUid} {
          allow read: if request.auth != null;
          allow create, update: if request.auth != null
            && voteUid == request.auth.uid
            && request.resource.data.keys().hasOnly(['vote', 'mood'])
            && request.resource.data.vote in ['up', 'down', '']
            && request.resource.data.mood in ['laugh', 'cry', 'awkward', ''];
          allow delete: if request.auth != null && voteUid == request.auth.uid;
        }
      }
    }

    /**
     * Tourgo Friends · v5 — friend code index.
     * Owner publishes their code → uid + name so others can search.
     */
    match /hideSeekFriendIndex/{friendCode} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.friendCode == friendCode
        && friendCode.matches('^[A-Z0-9]{4,8}$');
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    /**
     * Tourgo Friends · v5 — friend requests.
     * requestId convention: "{fromUid}_{toUid}". Sender creates pending,
     * recipient flips to accepted/rejected. On accept, both sides write
     * reciprocal docs in their /hideSeekFriends/{me}/friends/{other} list.
     */
    match /hideSeekFriendRequests/{reqId} {
      allow read: if request.auth != null
        && resource != null
        && (request.auth.uid == resource.data.fromUid
          || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toUid
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.status in ['accepted', 'rejected'];
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.fromUid
          || request.auth.uid == resource.data.toUid);
    }

    /**
     * Tourgo Friends · v5 — accepted friend connections (per-user list).
     */
    match /hideSeekFriends/{ownerUid}/friends/{otherUid} {
      allow read: if request.auth != null && request.auth.uid == ownerUid;
      allow create, update: if request.auth != null
        && (request.auth.uid == ownerUid || request.auth.uid == otherUid)
        && request.resource.data.uid == otherUid;
      allow delete: if request.auth != null && request.auth.uid == ownerUid;
    }

    /**
     * Tourgo Friends · v5 — manhunt rooms.
     * Permissive but auth-gated rules. Hosts and members manage room state
     * collaboratively. Captures locked to the hunt phase.
     */
    match /hideSeekRooms/{roomCode} {
      function inRoom() {
        return exists(/databases/$(database)/documents/hideSeekRooms/$(roomCode)/members/$(request.auth.uid));
      }
      function isHost() {
        return request.auth != null
          && exists(/databases/$(database)/documents/hideSeekRooms/$(roomCode))
          && get(/databases/$(database)/documents/hideSeekRooms/$(roomCode)).data.hostUid == request.auth.uid;
      }

      allow read: if request.auth != null;
      allow create: if request.auth != null
        && roomCode is string
        && roomCode.matches('^[A-Z0-9]{4,8}$')
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'lobby';
      allow update: if request.auth != null && inRoom();
      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;

      match /members/{memberUid} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == memberUid
          && request.resource.data.uid == memberUid;
        allow update: if request.auth != null
          && (request.auth.uid == memberUid
            || isHost()
            || (
              // Allow other members to mark you captured (Hunter capturing Runner)
              request.resource.data.uid == resource.data.uid
              && request.resource.data.name == resource.data.name
              && request.resource.data.qrToken == resource.data.qrToken
              && exists(/databases/$(database)/documents/hideSeekRooms/$(roomCode)/members/$(request.auth.uid))
            )
          );
        allow delete: if request.auth != null
          && (request.auth.uid == memberUid || isHost());
      }

      match /captures/{targetUid} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.captorUid == request.auth.uid
          && request.resource.data.targetUid == targetUid
          && request.resource.data.targetUid != request.auth.uid
          && exists(/databases/$(database)/documents/hideSeekRooms/$(roomCode)/members/$(request.auth.uid))
          && exists(/databases/$(database)/documents/hideSeekRooms/$(roomCode)/members/$(targetUid))
          && get(/databases/$(database)/documents/hideSeekRooms/$(roomCode)).data.status in ['hunt', 'stalemate'];
        allow update, delete: if false;
      }

      match /chats/{messageId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/hideSeekRooms/$(roomCode)/members/$(request.auth.uid));
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/hideSeekRooms/$(roomCode)/members/$(request.auth.uid))
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 500
          && request.resource.data.scope in ['all', 'hunters', 'runners'];
        allow update, delete: if false;
      }
    }
  }
}
